# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Proveedor de Drive: apps_script o google_cloud.
DRIVE_PROVIDER=apps_script

# Google Drive sin Google Cloud, usando Apps Script.
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=
GOOGLE_APPS_SCRIPT_SECRET=

# Google Drive con cuenta de servicio, opcional si DRIVE_PROVIDER=google_cloud.
# Comparte las carpetas de Drive con GOOGLE_CLIENT_EMAIL.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Carpeta raiz donde se creara una subcarpeta por folio para documentos aprobados.
GOOGLE_DRIVE_APPROVED_FOLDER_ID=

# Log CSV: usa un folder para que la app cree/actualice documentos-contratacion-log.csv.
GOOGLE_DRIVE_LOG_FOLDER_ID=

# Alternativa: fija un archivo CSV existente para actualizarlo directamente.
GOOGLE_DRIVE_LOG_FILE_ID=
GOOGLE_DRIVE_LOG_FILE_NAME=documentos-contratacion-log.csv
